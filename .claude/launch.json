{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI (dev)",
      "runtimeExecutable": "arch",
      "runtimeArgs": ["-x86_64", "/usr/local/bin/python3.11", "-m", "uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Frontend (static)",
      "runtimeExecutable": "/usr/local/bin/python3.11",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "frontend"],
      "port": 3000
    }
  ]
}
